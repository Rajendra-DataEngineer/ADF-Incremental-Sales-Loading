{
	"name": "df_silver_to_gold",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "ls_adls_gen2",
						"type": "LinkedServiceReference"
					},
					"name": "SilverSalesDelta"
				},
				{
					"dataset": {
						"referenceName": "salesdata1",
						"type": "DatasetReference"
					},
					"name": "SilverSalesCsv"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_gold_sales",
						"type": "DatasetReference"
					},
					"name": "GoldSalesSink"
				},
				{
					"dataset": {
						"referenceName": "ds_quarantine_silver_sales",
						"type": "DatasetReference"
					},
					"name": "QuarantineSink"
				}
			],
			"transformations": [
				{
					"name": "MapDriftedSales"
				},
				{
					"name": "AssertSalesRequired"
				},
				{
					"name": "SplitValidInvalid"
				},
				{
					"name": "ValidWithKey"
				},
				{
					"name": "JoinWithDelta"
				},
				{
					"name": "AggregateGold"
				},
				{
					"name": "QuarantineRows"
				}
			],
			"scriptLines": [
				"source(output(",
				"          SaleID as integer,",
				"          CustomerID as integer,",
				"          Amount as double,",
				"          SaleDate as date,",
				"          IngestionDate as date",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: true,",
				"     inferDriftedColumnTypes: true,",
				"     format: 'delta',",
				"     fileSystem: 'silver',",
				"     folderPath: 'sales_transformed') ~> SilverSalesDelta",
				"source(output(",
				"          saleID as string,",
				"          Product as string,",
				"          amount as string,",
				"          saledate as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     inferDriftedColumnTypes: true) ~> SilverSalesCsv",
				"SilverSalesCsv derive(",
				"          saleID = toString(coalesce(byName('saleID'), byName('SaleID'), byName('sale_id'))),",
				"          Product = toString(coalesce(byName('Product'), byName('product'), byName('ProductName'))),",
				"          amount = toString(coalesce(byName('amount'), byName('Amount'), byName('sales_amount'))),",
				"          saledate = toString(coalesce(byName('saledate'), byName('SaleDate'), byName('sale_date')))",
				"     ) ~> MapDriftedSales",
				"MapDriftedSales assert(expectTrue(!isNull(Product) && Product != '', false, 'Product'),",
				"     expectTrue(!isNull(amount) && amount != '', false, 'amount')) ~> AssertSalesRequired",
				"AssertSalesRequired split(validRows = !isNull(Product) && Product != '' && !isNull(amount) && amount != '',",
				"     invalidRows = isNull(Product) || Product == '' || isNull(amount) || amount == '') ~> SplitValidInvalid",
				"SplitValidInvalid@validRows derive(SaleID = toInteger(saleID)) ~> ValidWithKey",
				"ValidWithKey, SilverSalesDelta join(ValidWithKey@SaleID == SilverSalesDelta@SaleID,",
				"     joinType:'left',",
				"     broadcast: 'auto')~> JoinWithDelta",
				"JoinWithDelta aggregate(groupBy(Product),",
				"     totalsales = sum(toInteger(amount)),",
				"     totalamount = sum(Amount),",
				"     customercount = count(CustomerID)) ~> AggregateGold",
				"AggregateGold sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> GoldSalesSink",
				"SplitValidInvalid@invalidRows derive(errorReason = 'Missing or invalid Product/amount',",
				"     quarantineTimestamp = currentTimestamp()) ~> QuarantineRows",
				"QuarantineRows sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> QuarantineSink"
			]
		}
	}
}
