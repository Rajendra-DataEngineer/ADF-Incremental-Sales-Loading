{
	"name": "df_customer_bronze_to_silver",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_bronze_customers",
						"type": "DatasetReference"
					},
					"name": "BronzeCustomers"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "SilverCustomersSink"
				}
			],
			"scriptLines": [
				"source(output(",
				"          CustomerID as string,",
				"          CustomerName as string,",
				"          Country as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> BronzeCustomers",
				"BronzeCustomers derive(loaddate = currentTimestamp()) ~> SilverCustomersSink"
			]
		}
	}
}