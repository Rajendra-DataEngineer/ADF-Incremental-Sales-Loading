{
	"name": "df_customer_bronze_to_silver",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_bronze_customers",
						"type": "DatasetReference"
					},
					"name": "BronzeCustomers"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_silver_customers",
						"type": "DatasetReference"
					},
					"name": "WriteToSilverContainer"
				}
			],
			"transformations": [
				{
					"name": "SilverCustomersSink"
				}
			],
			"scriptLines": [
				"source(output(",
				"          CustomerID as string,",
				"          CustomerName as string,",
				"          Country as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> BronzeCustomers",
				"BronzeCustomers derive(loaddate = currentTimestamp()) ~> SilverCustomersSink",
				"SilverCustomersSink sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> WriteToSilverContainer"
			]
		}
	}
}